---
import { BUSINESS } from "../lib/business";

export interface Props {
  items: Array<{ label: string; href: string }>;
}

const { items } = Astro.props;
const siteUrl = BUSINESS.urls.site;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-[var(--color-text-muted)]">
    <li>
      <a href="/" class="hover:text-[var(--color-primary)] transition-colors">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-[var(--color-border)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        {i === items.length - 1 ? (
          <span class="font-medium text-[var(--color-text)]">{item.label}</span>
        ) : (
          <a href={item.href} class="hover:text-[var(--color-primary)] transition-colors">{item.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
