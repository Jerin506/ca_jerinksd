---
import WhatsAppCTA from "./WhatsAppCTA.astro";

export interface Props {
  heading?: string;
  message?: string;
}

const {
  heading = "Have a question? It's faster on WhatsApp.",
  message = "Hello, I need your services",
} = Astro.props;
---

<section class="bg-[var(--color-primary-dark)] py-16 lg:py-20">
  <div class="container-site text-center">
    <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-6">{heading}</h2>
    <WhatsAppCTA message={message} label="Chat on WhatsApp" variant="white" />
  </div>
</section>
