---
import { BUSINESS } from "../lib/business";
import { waLink } from "../lib/whatsapp";

const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about/" },
  {
    label: "Services",
    href: "/services/",
    children: [
      { label: "Auditing & Assurance", href: "/services/auditing-and-assurance/" },
      { label: "Company Registration", href: "/services/company-registration/" },
      { label: "GST Compliance", href: "/services/gst-compliance/" },
      { label: "Income Tax Consulting", href: "/services/income-tax-consulting/" },
    ],
  },
  { label: "Contact", href: "/contact/" },
];

const whatsappUrl = waLink();
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-[var(--color-border)] transition-all duration-300 py-3 lg:py-4"
>
  <div class="container-site flex items-center justify-between gap-4">
    <!-- Logo / Wordmark -->
    <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Home — Jerin Kurian & Associates">
      <img src="/images/ca-india-logo.png" alt="CA India" class="h-10 w-auto shrink-0" width="40" height="40" />
      <div class="hidden sm:block">
        <div class="text-base lg:text-lg font-bold text-[var(--color-primary-dark)] leading-tight group-hover:text-[var(--color-primary)] transition-colors">
          {BUSINESS.name}
        </div>
        <div class="text-xs font-semibold text-[var(--color-accent-dark)] leading-tight">
          {BUSINESS.tagline}
        </div>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
      {navItems.map((item) =>
        item.children ? (
          <div class="relative group">
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors rounded-lg hover:bg-[var(--color-primary-light)] inline-flex items-center gap-1"
            >
              {item.label}
              <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <div class="bg-white rounded-xl shadow-lg border border-[var(--color-border)] py-2 min-w-[240px]">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary-light)] transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors rounded-lg hover:bg-[var(--color-primary-light)]"
          >
            {item.label}
          </a>
        )
      )}
    </nav>

    <!-- Desktop WhatsApp CTA -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener"
      class="hidden lg:inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-whatsapp)] hover:bg-[var(--color-whatsapp-dark)] text-white text-sm font-semibold rounded-full transition-colors shadow-sm hover:shadow-md"
    >
      <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp Us
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 rounded-lg hover:bg-[var(--color-bg-muted)] transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6 text-[var(--color-text)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 lg:hidden invisible opacity-0 transition-all duration-300"
    aria-hidden="true"
  >
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="mobile-menu-backdrop"></div>

    <!-- Drawer -->
    <div class="absolute right-0 top-0 h-full w-[300px] max-w-[85vw] bg-white shadow-2xl translate-x-full transition-transform duration-300 flex flex-col" id="mobile-drawer">
      <!-- Drawer header -->
      <div class="flex items-center justify-between p-4 border-b border-[var(--color-border)]">
        <div class="flex items-center gap-2">
          <img src="/images/ca-india-logo.png" alt="CA India" class="h-8 w-auto" width="32" height="32" />
          <span class="font-bold text-sm text-[var(--color-primary-dark)]">{BUSINESS.name}</span>
        </div>
        <button id="mobile-menu-close" class="p-2 rounded-lg hover:bg-[var(--color-bg-muted)] transition-colors" aria-label="Close menu">
          <svg class="w-5 h-5 text-[var(--color-text)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Drawer nav -->
      <nav class="flex-1 overflow-y-auto p-4 space-y-1" aria-label="Mobile navigation">
        {navItems.map((item) =>
          item.children ? (
            <div>
              <a href={item.href} class="block px-4 py-3 text-base font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary-light)] rounded-lg transition-colors">
                {item.label}
              </a>
              <div class="ml-4 mt-1 space-y-0.5 border-l-2 border-[var(--color-border)] pl-3">
                {item.children.map((child) => (
                  <a href={child.href} class="block px-3 py-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary-light)] rounded-lg transition-colors">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} class="block px-4 py-3 text-base font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary-light)] rounded-lg transition-colors">
              {item.label}
            </a>
          )
        )}
      </nav>

      <!-- Drawer WhatsApp CTA -->
      <div class="p-4 border-t border-[var(--color-border)]">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener"
          class="flex items-center justify-center gap-2 w-full px-5 py-3 bg-[var(--color-whatsapp)] hover:bg-[var(--color-whatsapp-dark)] text-white font-semibold rounded-full transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Header shrink on scroll
  const header = document.getElementById("site-header");
  if (header) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        header.classList.add("header-shrunk");
      } else {
        header.classList.remove("header-shrunk");
      }
    }, { passive: true });
  }

  // Mobile menu toggle
  const menuBtn = document.getElementById("mobile-menu-btn");
  const closeBtn = document.getElementById("mobile-menu-close");
  const backdrop = document.getElementById("mobile-menu-backdrop");
  const menu = document.getElementById("mobile-menu");
  const drawer = document.getElementById("mobile-drawer");

  function openMenu() {
    if (!menu || !drawer || !menuBtn) return;
    menu.classList.remove("invisible", "opacity-0");
    menu.classList.add("visible", "opacity-100");
    menu.setAttribute("aria-hidden", "false");
    drawer.classList.remove("translate-x-full");
    drawer.classList.add("translate-x-0");
    menuBtn.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    if (!menu || !drawer || !menuBtn) return;
    menu.classList.add("opacity-0");
    drawer.classList.remove("translate-x-0");
    drawer.classList.add("translate-x-full");
    menuBtn.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    setTimeout(() => {
      menu.classList.add("invisible");
      menu.classList.remove("visible", "opacity-100");
      menu.setAttribute("aria-hidden", "true");
    }, 300);
  }

  menuBtn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  backdrop?.addEventListener("click", closeMenu);

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });
</script>
