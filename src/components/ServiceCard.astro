---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="service-card block bg-white rounded-2xl border border-[var(--color-border)] p-6 lg:p-8 group">
  <div class="w-12 h-12 rounded-xl bg-[var(--color-primary-light)] flex items-center justify-center mb-4 text-[var(--color-primary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors duration-200">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-lg font-bold text-[var(--color-text)] mb-2 group-hover:text-[var(--color-primary)] transition-colors">{title}</h3>
  <p class="text-sm text-[var(--color-text-muted)] mb-4 leading-relaxed">{description}</p>
  <span class="text-sm font-semibold text-[var(--color-primary)] inline-flex items-center gap-1 group-hover:gap-2 transition-all">
    Learn more
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </span>
</a>
