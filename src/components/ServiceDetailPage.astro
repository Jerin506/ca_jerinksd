---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "./Breadcrumb.astro";
import FAQ from "./FAQ.astro";
import WhatsAppCTA from "./WhatsAppCTA.astro";
import CTABand from "./CTABand.astro";
import ServiceCard from "./ServiceCard.astro";
import { BUSINESS } from "../lib/business";
import { getServiceJsonLd, getFAQJsonLd, getBreadcrumbJsonLd } from "../lib/seo";
import type { ServiceData } from "../lib/services";
import { getRelatedServices } from "../lib/services";

export interface Props {
  service: ServiceData;
  seoTitle: string;
  seoDescription: string;
}

const { service, seoTitle, seoDescription } = Astro.props;

const related = getRelatedServices(service.slug);
const serviceUrl = `${BUSINESS.urls.site}/services/${service.slug}/`;

const serviceJsonLd = getServiceJsonLd({
  name: service.title,
  description: service.subtitle,
  url: serviceUrl,
});
const faqJsonLd = getFAQJsonLd(service.faqs);
const breadcrumbJsonLd = getBreadcrumbJsonLd([
  { name: "Home", url: BUSINESS.urls.site },
  { name: "Services", url: `${BUSINESS.urls.site}/services/` },
  { name: service.title, url: serviceUrl },
]);

const serviceIcons: Record<string, string> = {
  ShieldCheck: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>',
  Building2: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21"/></svg>',
  ReceiptText: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>',
  Calculator: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z"/></svg>',
};
---

<BaseLayout title={seoTitle} description={seoDescription} jsonLd={[serviceJsonLd, faqJsonLd, breadcrumbJsonLd]}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-white via-[var(--color-bg-muted)] to-[var(--color-primary-light)] section-padding">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14 items-center">
        <div>
          <Breadcrumb items={[{ label: "Services", href: "/services/" }, { label: service.title, href: `/services/${service.slug}/` }]} />
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-text)] mb-3">{service.title}</h1>
          <p class="text-lg text-[var(--color-text-muted)] max-w-2xl">{service.subtitle}</p>
        </div>
        <div class="hidden lg:block">
          <div class="relative">
            <div class="absolute -inset-3 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-orange)]/10 rounded-3xl blur-xl"></div>
            <img src={service.image} alt={service.title} class="relative rounded-2xl shadow-xl w-full h-auto" width="480" height="360" loading="eager" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-6">What We Do</h2>
      <ul class="space-y-3">
        {service.deliverables.map((d) => (
          <li class="flex items-start gap-3 text-[var(--color-text-muted)]">
            <svg class="w-5 h-5 text-[var(--color-accent)] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span class="leading-relaxed">{d}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="section-padding bg-[var(--color-bg-muted)]">
    <div class="container-site max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-4">Who It's For</h2>
      <p class="text-[var(--color-text-muted)] leading-relaxed">{service.whoItsFor}</p>
    </div>
  </section>

  <!-- Our Process -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-8">Our Process</h2>
      <div class="space-y-6">
        {service.process.map((step, i) => (
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-[var(--color-primary)] text-white flex items-center justify-center font-bold text-sm shrink-0">{i + 1}</div>
            <div>
              <h3 class="font-bold text-[var(--color-text)] mb-1">{step.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-[var(--color-bg-muted)]">
    <div class="container-site max-w-3xl text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-4">Ready to Get Started?</h2>
      <p class="text-[var(--color-text-muted)] mb-6">Reach out on WhatsApp for a quick consultation — we typically respond within a few hours.</p>
      <WhatsAppCTA message={service.whatsappMessage} label={`WhatsApp Us About ${service.shortTitle}`} />
    </div>
  </section>

  <!-- FAQs -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-6">Frequently Asked Questions</h2>
      <FAQ items={service.faqs} />
    </div>
  </section>

  <!-- Related Services -->
  <section class="section-padding bg-[var(--color-bg-muted)]">
    <div class="container-site">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-8 text-center">Other Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {related.map((r) => (
          <ServiceCard
            title={r.title}
            description={r.shortDescription}
            href={`/services/${r.slug}/`}
            icon={serviceIcons[r.icon] || ""}
          />
        ))}
      </div>
    </div>
  </section>

  <CTABand />
</BaseLayout>
