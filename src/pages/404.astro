---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Page Not Found | Jerin Kurian & Associates";
const description = "The page you're looking for doesn't exist. Navigate back to our home page or explore our services.";
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-white min-h-[60vh] flex items-center">
    <div class="container-site text-center">
      <div class="text-8xl md:text-9xl font-bold text-[var(--color-primary-light)] mb-4 select-none">404</div>
      <h1 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-3">This page took a tax holiday.</h1>
      <p class="text-[var(--color-text-muted)] mb-8 max-w-md mx-auto">The page you're looking for doesn't exist or may have been moved. Let's get you back on track.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-12">
        <a href="/" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-semibold rounded-full transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
          Go Home
        </a>
        <a href="/services/" class="inline-flex items-center justify-center gap-2 px-6 py-3 border-2 border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] font-semibold rounded-full transition-all">
          Explore Services
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 max-w-2xl mx-auto">
        <a href="/services/auditing-and-assurance/" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors py-2 px-3 rounded-lg hover:bg-[var(--color-primary-light)]">Auditing & Assurance</a>
        <a href="/services/company-registration/" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors py-2 px-3 rounded-lg hover:bg-[var(--color-primary-light)]">Company Registration</a>
        <a href="/services/gst-compliance/" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors py-2 px-3 rounded-lg hover:bg-[var(--color-primary-light)]">GST Compliance</a>
        <a href="/services/income-tax-consulting/" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors py-2 px-3 rounded-lg hover:bg-[var(--color-primary-light)]">Income Tax</a>
      </div>
    </div>
  </section>
</BaseLayout>
