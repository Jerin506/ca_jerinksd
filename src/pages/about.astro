---
import BaseLayout from "../layouts/BaseLayout.astro";
import WhatsAppCTA from "../components/WhatsAppCTA.astro";
import CTABand from "../components/CTABand.astro";
import { BUSINESS } from "../lib/business";
import { getBreadcrumbJsonLd } from "../lib/seo";

const title = "About Us | Jerin Kurian & Associates, Chartered Accountants";
const description = "Learn about Jerin Kurian & Associates — an ICAI-registered Chartered Accountancy firm in Bangalore offering audit, GST, tax, and company registration services.";
const breadcrumbLd = getBreadcrumbJsonLd([
  { name: "Home", url: BUSINESS.urls.site },
  { name: "About", url: `${BUSINESS.urls.site}/about/` },
]);

const values = [
  { icon: '<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>', title: "Integrity", desc: "We uphold the highest ethical standards in every engagement. Your financial data is handled with complete confidentiality and care." },
  { icon: '<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>', title: "Clarity", desc: "No jargon, no hidden surprises. We explain complex regulations in plain language so you can make informed decisions." },
  { icon: '<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>', title: "Responsiveness", desc: "Reach us on WhatsApp and get a same-day response. We respect your time and work around your schedule." },
];
---

<BaseLayout title={title} description={description} jsonLd={[breadcrumbLd]}>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-white via-[var(--color-bg-muted)] to-[var(--color-primary-light)] section-padding">
    <div class="container-site">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-text)] mb-4">About {BUSINESS.name}</h1>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl">A trusted Chartered Accountancy firm based in Bangalore.</p>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <span class="inline-block px-3 py-1 bg-[var(--color-primary-light)] text-[var(--color-primary)] text-xs font-bold uppercase tracking-wider rounded-full mb-4">Who We Are</span>
          <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-6">A Bangalore-Based CA Firm</h2>
          <div class="space-y-4 text-[var(--color-text-muted)] leading-relaxed">
            <p>Jerin Kurian & Associates is a professional Chartered Accountancy firm registered with the Institute of Chartered Accountants of India (ICAI). Based in Bangalore, we serve individuals, startups, SMEs, and established businesses across Karnataka.</p>
            <p>Our practice is built around four core service pillars: <strong class="text-[var(--color-text)]">Auditing & Assurance</strong>, <strong class="text-[var(--color-text)]">Company Registration</strong>, <strong class="text-[var(--color-text)]">GST Compliance & Advisory</strong>, and <strong class="text-[var(--color-text)]">Income Tax Consulting</strong>. Each engagement is handled with the rigour and attention to detail that our clients expect from a qualified CA firm.</p>
            <p>We believe that accessible, high-quality financial services should not be limited to large corporations. Whether you need a one-time ITR filing or ongoing audit support, we bring the same level of professionalism to every client.</p>
          </div>
        </div>
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-tr from-[var(--color-primary)]/10 to-[var(--color-accent)]/10 rounded-3xl blur-xl"></div>
          <img src="/images/about/office.png" alt="Professional chartered accountancy office" class="relative rounded-2xl shadow-xl w-full h-auto" width="560" height="400" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Founder -->
  <section class="section-padding bg-[var(--color-bg-muted)]">
    <div class="container-site max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-8">Our Founder</h2>
      <div class="flex flex-col sm:flex-row gap-8 items-start">
        <!-- TODO: Replace placeholder with real founder photo -->
        <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-2xl bg-[var(--color-primary-light)] flex items-center justify-center shrink-0">
          <svg class="w-16 h-16 text-[var(--color-primary)]/30" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-[var(--color-text)] mb-1">{BUSINESS.founder.name}</h3>
          <p class="text-sm font-medium text-[var(--color-primary)] mb-4">Chartered Accountant</p>
          <!-- TODO: Owner to provide final bio -->
          <p class="text-[var(--color-text-muted)] leading-relaxed">{BUSINESS.founder.bio}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-10 text-center">Our Values</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
        {values.map((v) => (
          <div class="text-center bg-white rounded-2xl p-8 shadow-sm border border-[var(--color-border)] hover:shadow-md transition-shadow">
            <div class="w-14 h-14 rounded-2xl bg-[var(--color-primary-light)] flex items-center justify-center mx-auto mb-4 text-[var(--color-primary)]">
              <Fragment set:html={v.icon} />
            </div>
            <h3 class="text-lg font-bold text-[var(--color-text)] mb-2">{v.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand heading="Ready to work with a CA you can trust?" />
</BaseLayout>
