---
import BaseLayout from "../layouts/BaseLayout.astro";
import WhatsAppCTA from "../components/WhatsAppCTA.astro";
import MapEmbed from "../components/MapEmbed.astro";
import { BUSINESS } from "../lib/business";
import { getBreadcrumbJsonLd } from "../lib/seo";

const title = "Contact Jerin Kurian & Associates — CA Firm in Bangalore";
const description = "Get in touch with Jerin Kurian & Associates, Chartered Accountants in Bangalore. Visit our office or WhatsApp us for a same-day response.";
const breadcrumbLd = getBreadcrumbJsonLd([
  { name: "Home", url: BUSINESS.urls.site },
  { name: "Contact", url: `${BUSINESS.urls.site}/contact/` },
]);
---

<BaseLayout title={title} description={description} jsonLd={[breadcrumbLd]}>
  <section class="bg-gradient-to-br from-white via-[var(--color-bg-muted)] to-[var(--color-primary-light)] section-padding">
    <div class="container-site">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[var(--color-text)] mb-4">Get in Touch</h1>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl">We respond fastest on WhatsApp. Reach out for a quick consultation or visit our office in Bangalore.</p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14">
        <!-- Left: Contact Info -->
        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-6">Contact Details</h2>
          <div class="space-y-5 mb-8">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-[var(--color-primary-light)] flex items-center justify-center text-[var(--color-primary)] shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-[var(--color-text)] text-sm mb-1">Office Address</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{BUSINESS.address.full}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-[var(--color-primary-light)] flex items-center justify-center text-[var(--color-primary)] shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-[var(--color-text)] text-sm mb-1">WhatsApp / Call</h3>
                <a href={BUSINESS.phone.tel} class="text-sm text-[var(--color-primary)] font-medium hover:text-[var(--color-primary-dark)] transition-colors">{BUSINESS.phone.display}</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-[var(--color-primary-light)] flex items-center justify-center text-[var(--color-primary)] shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-[var(--color-text)] text-sm mb-1">Business Hours</h3>
                <p class="text-sm text-[var(--color-text-muted)]">{BUSINESS.hours.display}</p>
              </div>
            </div>
          </div>
          <div class="bg-[var(--color-bg-muted)] rounded-2xl p-6 mb-6">
            <p class="text-sm text-[var(--color-text-muted)] mb-4">💬 We respond fastest on WhatsApp — typically within a few hours.</p>
            <WhatsAppCTA message="Hello, I need your services" label="Chat on WhatsApp" />
          </div>
          <a href={BUSINESS.phone.tel} class="inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            Prefer to call? Tap to dial.
          </a>
        </div>
        <!-- Right: Map -->
        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-6">Find Us</h2>
          <MapEmbed />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
