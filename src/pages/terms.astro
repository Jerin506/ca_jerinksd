---
import BaseLayout from "../layouts/BaseLayout.astro";
import { BUSINESS } from "../lib/business";

const title = "Terms of Service | Jerin Kurian & Associates";
const description = "Terms of service for Jerin Kurian & Associates, Chartered Accountants in Bangalore.";
---

<!-- LEGAL REVIEW REQUIRED before launch -->
<BaseLayout title={title} description={description}>
  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-8">Terms of Service</h1>

      <!-- TODO: This is a boilerplate terms page. The firm's lawyer should review and customize before launch. -->
      <div class="prose prose-sm max-w-none text-[var(--color-text-muted)] space-y-6">
        <p class="text-sm text-[var(--color-text-muted)] italic bg-amber-50 border border-amber-200 rounded-lg p-4">⚠️ This is a placeholder terms of service. It must be reviewed and customized by a legal professional before the website goes live.</p>

        <h2 class="text-xl font-bold text-[var(--color-text)] mt-8 mb-3">1. Services</h2>
        <p>{BUSINESS.legalName} provides chartered accountancy services including auditing, company registration, GST compliance, and income tax consulting. The scope of each engagement is agreed upon individually with the client.</p>

        <h2 class="text-xl font-bold text-[var(--color-text)] mt-8 mb-3">2. Professional Standards</h2>
        <p>All services are provided in accordance with the standards and guidelines issued by the Institute of Chartered Accountants of India (ICAI) and applicable laws and regulations.</p>

        <h2 class="text-xl font-bold text-[var(--color-text)] mt-8 mb-3">3. Client Responsibilities</h2>
        <p>Clients are responsible for providing accurate and complete information necessary for the performance of our services. Delays in providing required documents may affect timelines.</p>

        <h2 class="text-xl font-bold text-[var(--color-text)] mt-8 mb-3">4. Confidentiality</h2>
        <p>We maintain strict confidentiality of all client information in accordance with professional ethics and applicable privacy laws.</p>

        <h2 class="text-xl font-bold text-[var(--color-text)] mt-8 mb-3">5. Limitation of Liability</h2>
        <p>Our liability is limited to the fees received for the specific engagement in question. We are not liable for any indirect, consequential, or incidental damages.</p>

        <h2 class="text-xl font-bold text-[var(--color-text)] mt-8 mb-3">6. Website Disclaimer</h2>
        <p>The information on this website is for general informational purposes only and does not constitute professional advice. For specific advice, please contact us directly.</p>

        <h2 class="text-xl font-bold text-[var(--color-text)] mt-8 mb-3">7. Contact</h2>
        <p>For questions about these terms, contact us at <a href={`https://wa.me/${BUSINESS.phone.whatsapp}`} class="text-[var(--color-primary)] hover:underline">{BUSINESS.phone.display}</a>.</p>

        <p class="text-xs text-[var(--color-text-muted)] mt-8">Last updated: {new Date().toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      </div>
    </div>
  </section>
</BaseLayout>
